name: Deploy STLCityRoute

on:
  push:
    branches: [ main ]

jobs:
  deploy:
    runs-on: ubuntu-latest
    permissions:
      contents: write
      pages: write
      id-token: write

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Generate version
        id: ver
        run: echo "V=$(date +'%Y%m%d')-$(git rev-parse --short HEAD)" >> $GITHUB_OUTPUT

      - name: Stamp version into sw.js
        run: sed -i "s/%%VERSION%%/${{ steps.ver.outputs.V }}/g" sw.js

      - name: Stamp version into index.html
        run: |
          sed -i "s/%%VERSION%%/${{ steps.ver.outputs.V }}/g" index.html

      - name: Deploy to GitHub Pages
        uses: peaceiris/actions-gh-pages@v3
        with:
          github_token: ${{ secrets.GITHUB_TOKEN }}
          publish_dir: ./
          publish_branch: gh-pages
          exclude_assets: '.github'
